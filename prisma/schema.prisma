// Prisma schema - Punto de Venta Empresarial
// Migraciones versionadas con Prisma Migrate (nunca modificar migraciones anteriores)

generator client {
  provider      = "prisma-client-js"
  // Linux (dev/CI) + Windows (instalador Electron)
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Multi-empresa / Multi-sucursal (preparado para futuro) ─────────────────

model Company {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(50)
  email     String?  @db.VarChar(150)
  phone     String?  @db.VarChar(30)
  address   String?  @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches Branch[]
  users    User[]

  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid()) @db.Char(36)
  companyId String   @map("company_id") @db.Char(36)
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(200)
  address   String?  @db.VarChar(500)
  phone     String?  @db.VarChar(30)
  isActive  Boolean  @default(true) @map("is_active")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id])
  registers           Register[]
  terminals           Terminal[]
  products            Product[]
  categories          Category[]
  customers           Customer[]
  suppliers           Supplier[]
  sales               Sale[]
  purchases           Purchase[]
  inventoryItems      InventoryItem[]
  inventoryAdjustments InventoryAdjustment[]
  businessConfig      BusinessConfig?
  productImportTypes  ProductImportType[]

  @@unique([companyId, code])
  @@map("branches")
}

// ─── Autenticación, Usuarios, Roles y Permisos ─────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Char(36)
  companyId    String    @map("company_id") @db.Char(36)
  username     String    @unique @db.VarChar(50)
  email        String?   @unique @db.VarChar(150)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  pin          String?   @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  userRoles          UserRole[]
  userRegisters      UserRegister[]
  registerSessions   RegisterSession[]
  sales              Sale[]
  purchases          Purchase[]
  cashMovements      CashMovement[]
  inventoryAdjustments InventoryAdjustment[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Char(36)
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  roleId    String   @map("role_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Char(36)
  roleId       String   @map("role_id") @db.Char(36)
  permissionId String   @map("permission_id") @db.Char(36)
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Configuración del negocio ──────────────────────────────────────────────

model BusinessConfig {
  id                String   @id @default(uuid()) @db.Char(36)
  branchId          String   @unique @map("branch_id") @db.Char(36)
  businessName      String   @map("business_name") @db.VarChar(200)
  taxId             String?  @map("tax_id") @db.VarChar(50)
  address           String?  @db.VarChar(500)
  phone             String?  @db.VarChar(30)
  email             String?  @db.VarChar(150)
  currency          String   @default("COP") @db.VarChar(3)
  currencySymbol    String   @default("$") @map("currency_symbol") @db.VarChar(5)
  taxRate           Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  ticketHeader      String?  @map("ticket_header") @db.Text
  ticketFooter      String?  @map("ticket_footer") @db.Text
  allowNegativeStock Boolean @default(false) @map("allow_negative_stock")
  defaultCustomerId String?  @map("default_customer_id") @db.Char(36)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("business_config")
}

model AppSetting {
  id        String   @id @default(uuid()) @db.Char(36)
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  category  String   @default("general") @db.VarChar(50)
  isSecret  Boolean  @default(false) @map("is_secret")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─── Cajas (Registers) ──────────────────────────────────────────────────────

enum RegisterSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  INCOME
  EXPENSE
  WITHDRAWAL
  DEPOSIT
  SALE
  REFUND
}

model Register {
  id          String   @id @default(uuid()) @db.Char(36)
  branchId    String   @map("branch_id") @db.Char(36)
  code        String   @db.VarChar(20)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch           Branch            @relation(fields: [branchId], references: [id])
  sessions         RegisterSession[]
  sales            Sale[]
  userRegisters    UserRegister[]
  terminals        Terminal[]

  @@unique([branchId, code])
  @@map("registers")
}

model Terminal {
  id         String    @id @default(uuid()) @db.Char(36)
  branchId   String    @map("branch_id") @db.Char(36)
  registerId String?   @map("register_id") @db.Char(36)
  deviceId   String    @unique @map("device_id") @db.VarChar(100)
  name       String    @db.VarChar(150)
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  isActive   Boolean   @default(true) @map("is_active")
  lastSeenAt DateTime? @map("last_seen_at")
  lastScanAt DateTime? @map("last_scan_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  branch   Branch    @relation(fields: [branchId], references: [id])
  register Register? @relation(fields: [registerId], references: [id])

  @@map("terminals")
}

model UserRegister {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @map("user_id") @db.Char(36)
  registerId String   @map("register_id") @db.Char(36)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  register Register @relation(fields: [registerId], references: [id], onDelete: Cascade)

  @@unique([userId, registerId])
  @@map("user_registers")
}

model RegisterSession {
  id              String                @id @default(uuid()) @db.Char(36)
  registerId      String                @map("register_id") @db.Char(36)
  userId          String                @map("user_id") @db.Char(36)
  status          RegisterSessionStatus @default(OPEN)
  openingAmount   Decimal               @map("opening_amount") @db.Decimal(12, 2)
  closingAmount   Decimal?              @map("closing_amount") @db.Decimal(12, 2)
  expectedAmount  Decimal?              @map("expected_amount") @db.Decimal(12, 2)
  difference      Decimal?              @db.Decimal(12, 2)
  openedAt        DateTime              @default(now()) @map("opened_at")
  closedAt        DateTime?             @map("closed_at")
  openingNotes    String?               @map("opening_notes") @db.VarChar(500)
  closingNotes    String?               @map("closing_notes") @db.VarChar(500)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  register      Register       @relation(fields: [registerId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  cashMovements CashMovement[]
  sales         Sale[]

  @@map("register_sessions")
}

model CashMovement {
  id                String           @id @default(uuid()) @db.Char(36)
  registerSessionId String           @map("register_session_id") @db.Char(36)
  userId            String           @map("user_id") @db.Char(36)
  type              CashMovementType
  amount            Decimal          @db.Decimal(12, 2)
  description       String?          @db.VarChar(500)
  reference         String?          @db.VarChar(100)
  createdAt         DateTime         @default(now()) @map("created_at")

  registerSession RegisterSession @relation(fields: [registerSessionId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@map("cash_movements")
}

// ─── Catálogos: Categorías y Productos ──────────────────────────────────────

model UnitType {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productUnits  ProductUnit[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]

  @@map("unit_types")
}

/// Plantilla de mapeo Excel → campos de producto para importaciones.
model ProductImportType {
  id            String   @id @default(uuid()) @db.Char(36)
  branchId      String   @map("branch_id") @db.Char(36)
  code          String   @db.VarChar(30)
  name          String   @db.VarChar(100)
  description   String?  @db.VarChar(500)
  /// Encabezados detectados del Excel de muestra (string[]).
  sampleHeaders Json?    @map("sample_headers")
  /// Mapeo campoProducto → nombreColumnaExcel. Ej: { "sku": "CODIGO", "name": "NOMBRE" }
  mappings      Json
  /// Fila del Excel donde están los encabezados (1-based).
  headerRow     Int      @default(1) @map("header_row")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("product_import_types")
}

model Category {
  id          String   @id @default(uuid()) @db.Char(36)
  branchId    String   @map("branch_id") @db.Char(36)
  parentId    String?  @map("parent_id") @db.Char(36)
  code        String   @db.VarChar(30)
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch   Branch     @relation(fields: [branchId], references: [id])
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([branchId, code])
  @@map("categories")
}

enum ProductType {
  SIMPLE
  VARIABLE
  COMBO
  SERVICE
}

model Product {
  id            String      @id @default(uuid()) @db.Char(36)
  branchId      String      @map("branch_id") @db.Char(36)
  categoryId    String?     @map("category_id") @db.Char(36)
  sku           String      @db.VarChar(50)
  barcode       String?     @db.VarChar(50)
  name          String      @db.VarChar(200)
  description   String?     @db.VarChar(1000)
  type          ProductType @default(SIMPLE)
  costPrice     Decimal     @default(0) @map("cost_price") @db.Decimal(12, 4)
  salePrice     Decimal     @map("sale_price") @db.Decimal(12, 2)
  taxRate       Decimal?    @map("tax_rate") @db.Decimal(5, 2)
  unit          String      @default("PZA") @db.VarChar(20)
  minStock      Decimal     @default(0) @map("min_stock") @db.Decimal(12, 3)
  maxStock      Decimal?    @map("max_stock") @db.Decimal(12, 3)
  trackInventory Boolean    @default(true) @map("track_inventory")
  isActive      Boolean     @default(true) @map("is_active")
  imageUrl      String?     @map("image_url") @db.VarChar(500)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  branch              Branch                @relation(fields: [branchId], references: [id])
  category            Category?             @relation(fields: [categoryId], references: [id])
  barcodes            ProductBarcode[]
  inventoryItems      InventoryItem[]
  productUnits        ProductUnit[]
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]
  adjustmentItems     InventoryAdjustmentItem[]

  @@unique([branchId, sku])
  @@index([branchId, barcode])
  @@index([branchId, name])
  @@map("products")
}

model ProductUnit {
  id          String  @id @default(uuid()) @db.Char(36)
  productId   String  @map("product_id") @db.Char(36)
  unitTypeId  String  @map("unit_type_id") @db.Char(36)
  /// Cuántas unidades de inventario (stock base) representa 1 de esta unidad.
  /// Ej: CAJA con stockFactor=12 → vender 1 caja descuenta 12 del stock.
  stockFactor Decimal @default(1) @map("stock_factor") @db.Decimal(12, 4)
  isBase      Boolean @default(false) @map("is_base")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitType UnitType @relation(fields: [unitTypeId], references: [id])

  @@unique([productId, unitTypeId])
  @@index([unitTypeId])
  @@map("product_units")
}

model ProductBarcode {
  id        String   @id @default(uuid()) @db.Char(36)
  productId String   @map("product_id") @db.Char(36)
  barcode   String   @db.VarChar(50)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([barcode])
  @@index([productId])
  @@map("product_barcodes")
}

// ─── Clientes y Proveedores ─────────────────────────────────────────────────

model Customer {
  id          String   @id @default(uuid()) @db.Char(36)
  branchId    String   @map("branch_id") @db.Char(36)
  code        String   @db.VarChar(30)
  name        String   @db.VarChar(200)
  taxId       String?  @map("tax_id") @db.VarChar(50)
  email       String?  @db.VarChar(150)
  phone       String?  @db.VarChar(30)
  address     String?  @db.VarChar(500)
  creditLimit Decimal? @map("credit_limit") @db.Decimal(12, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id])
  sales  Sale[]

  @@unique([branchId, code])
  @@index([branchId, name])
  @@map("customers")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  String   @map("branch_id") @db.Char(36)
  code      String   @db.VarChar(30)
  name      String   @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(50)
  email     String?  @db.VarChar(150)
  phone     String?  @db.VarChar(30)
  address   String?  @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch    Branch     @relation(fields: [branchId], references: [id])
  purchases Purchase[]

  @@unique([branchId, code])
  @@map("suppliers")
}

// ─── Inventario ─────────────────────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  String   @map("branch_id") @db.Char(36)
  productId String   @map("product_id") @db.Char(36)
  quantity  Decimal  @default(0) @db.Decimal(12, 3)
  reserved  Decimal  @default(0) @db.Decimal(12, 3)
  version   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
  @@map("inventory_items")
}

enum AdjustmentType {
  INCREASE
  DECREASE
  SET
}

enum AdjustmentStatus {
  DRAFT
  APPLIED
  CANCELLED
}

model InventoryAdjustment {
  id          String           @id @default(uuid()) @db.Char(36)
  branchId    String           @map("branch_id") @db.Char(36)
  userId      String           @map("user_id") @db.Char(36)
  type        AdjustmentType
  status      AdjustmentStatus @default(DRAFT)
  reason      String?          @db.VarChar(500)
  reference   String?          @db.VarChar(100)
  appliedAt   DateTime?        @map("applied_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  branch  Branch                    @relation(fields: [branchId], references: [id])
  user    User                      @relation(fields: [userId], references: [id])
  items   InventoryAdjustmentItem[]

  @@map("inventory_adjustments")
}

model InventoryAdjustmentItem {
  id           String  @id @default(uuid()) @db.Char(36)
  adjustmentId String  @map("adjustment_id") @db.Char(36)
  productId    String  @map("product_id") @db.Char(36)
  quantity     Decimal @db.Decimal(12, 3)
  previousQty  Decimal @map("previous_qty") @db.Decimal(12, 3)
  newQty       Decimal @map("new_qty") @db.Decimal(12, 3)

  adjustment InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product    Product             @relation(fields: [productId], references: [id])

  @@map("inventory_adjustment_items")
}

// ─── Compras ────────────────────────────────────────────────────────────────

enum PurchaseStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

model Purchase {
  id           String         @id @default(uuid()) @db.Char(36)
  branchId     String         @map("branch_id") @db.Char(36)
  supplierId   String         @map("supplier_id") @db.Char(36)
  userId       String         @map("user_id") @db.Char(36)
  documentNumber String       @map("document_number") @db.VarChar(50)
  status       PurchaseStatus @default(DRAFT)
  subtotal     Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total        Decimal        @default(0) @db.Decimal(12, 2)
  notes        String?        @db.VarChar(1000)
  receivedAt   DateTime?      @map("received_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  branch   Branch         @relation(fields: [branchId], references: [id])
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  items    PurchaseItem[]

  @@unique([branchId, documentNumber])
  @@map("purchases")
}

model PurchaseItem {
  id          String  @id @default(uuid()) @db.Char(36)
  purchaseId  String  @map("purchase_id") @db.Char(36)
  productId   String  @map("product_id") @db.Char(36)
  unitTypeId  String? @map("unit_type_id") @db.Char(36)
  quantity    Decimal @db.Decimal(12, 3)
  stockFactor Decimal @default(1) @map("stock_factor") @db.Decimal(12, 4)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 4)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  unitType UnitType? @relation(fields: [unitTypeId], references: [id])

  @@map("purchase_items")
}

// ─── Ventas ─────────────────────────────────────────────────────────────────

enum SaleStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
  VOIDED
}

model PaymentType {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(30)
  name        String   @db.VarChar(100)
  affectsCash Boolean  @default(false) @map("affects_cash")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payments SalePayment[]

  @@map("payment_types")
}

model Sale {
  id                String     @id @default(uuid()) @db.Char(36)
  branchId          String     @map("branch_id") @db.Char(36)
  registerId        String     @map("register_id") @db.Char(36)
  registerSessionId String?    @map("register_session_id") @db.Char(36)
  userId            String     @map("user_id") @db.Char(36)
  customerId        String?    @map("customer_id") @db.Char(36)
  tabId             String?    @map("tab_id") @db.VarChar(50)
  tabOrder          Int        @default(0) @map("tab_order")
  documentNumber    String?    @map("document_number") @db.VarChar(50)
  status            SaleStatus @default(DRAFT)
  subtotal          Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountPercent   Decimal    @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxAmount         Decimal    @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total             Decimal    @default(0) @db.Decimal(12, 2)
  amountPaid        Decimal    @default(0) @map("amount_paid") @db.Decimal(12, 2)
  changeAmount      Decimal    @default(0) @map("change_amount") @db.Decimal(12, 2)
  notes             String?    @db.VarChar(1000)
  version           Int        @default(0)
  completedAt       DateTime?  @map("completed_at")
  suspendedAt       DateTime?  @map("suspended_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  branch          Branch           @relation(fields: [branchId], references: [id])
  register        Register         @relation(fields: [registerId], references: [id])
  registerSession RegisterSession? @relation(fields: [registerSessionId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  items           SaleItem[]
  payments        SalePayment[]

  @@index([branchId, status])
  @@index([registerId, status])
  @@index([tabId])
  @@map("sales")
}

model SaleItem {
  id              String  @id @default(uuid()) @db.Char(36)
  saleId          String  @map("sale_id") @db.Char(36)
  productId       String  @map("product_id") @db.Char(36)
  unitTypeId      String? @map("unit_type_id") @db.Char(36)
  quantity        Decimal @db.Decimal(12, 3)
  /// Factor aplicado al stock al momento de la venta (snapshot).
  stockFactor     Decimal @default(1) @map("stock_factor") @db.Decimal(12, 4)
  unitPrice       Decimal @map("unit_price") @db.Decimal(12, 2)
  costPrice       Decimal @map("cost_price") @db.Decimal(12, 4)
  discountAmount  Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount       Decimal @default(0) @map("tax_amount") @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)
  total           Decimal @db.Decimal(12, 2)
  notes           String? @db.VarChar(500)

  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  unitType UnitType? @relation(fields: [unitTypeId], references: [id])

  @@map("sale_items")
}

model SalePayment {
  id            String   @id @default(uuid()) @db.Char(36)
  saleId        String   @map("sale_id") @db.Char(36)
  paymentTypeId String   @map("payment_type_id") @db.Char(36)
  amount        Decimal  @db.Decimal(12, 2)
  reference     String?  @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  sale        Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentType PaymentType @relation(fields: [paymentTypeId], references: [id])

  @@index([paymentTypeId])
  @@map("sale_payments")
}

// ─── Auditoría ──────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SALE
  VOID
  REFUND
  OPEN_REGISTER
  CLOSE_REGISTER
  ADJUST_INVENTORY
  CONFIG_CHANGE
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Char(36)
  userId     String?     @map("user_id") @db.Char(36)
  action     AuditAction
  module     String      @db.VarChar(50)
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id") @db.Char(36)
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.VarChar(500)
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([module, entityType])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Control de migraciones (metadatos adicionales) ─────────────────────────

model MigrationLog {
  id            String   @id @default(uuid()) @db.Char(36)
  migrationName String   @map("migration_name") @db.VarChar(255)
  appliedAt     DateTime @default(now()) @map("applied_at")
  durationMs    Int?     @map("duration_ms")
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message") @db.Text

  @@map("migration_logs")
}
