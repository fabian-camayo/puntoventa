{
  "name": "@puntoventa/desktop",
  "version": "1.0.0",
  "description": "PuntoVenta Desktop - Electron",
  "author": "PuntoVenta",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "start:dev": "tsc -p tsconfig.json --watch & electron .",
    "stage:api": "node ../../scripts/stage-desktop-api.js",
    "dist:win": "npm run build && npm run stage:api && electron-builder --win --x64 --projectDir .",
    "dist:linux": "npm run build && npm run stage:api && electron-builder --linux --projectDir ."
  },
  "build": {
    "appId": "com.puntoventa.desktop",
    "productName": "PuntoVenta",
    "electronVersion": "35.7.5",
    "directories": {
      "output": "../../dist/installer",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../www",
        "to": "www",
        "filter": ["**/*"]
      },
      {
        "from": ".packaging/api",
        "to": "api",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PuntoVenta",
      "include": "installer.nsh",
      "warningsAsErrors": false
    },
    "publish": {
      "provider": "generic",
      "url": "https://updates.puntoventa.local/"
    }
  },
  "dependencies": {
    "@puntoventa/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "typescript": "~5.9.0"
  }
}
