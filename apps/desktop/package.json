{
  "name": "@puntoventa/desktop",
  "version": "1.0.0",
  "description": "PuntoVenta Desktop - Electron",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "start:dev": "tsc -p tsconfig.json --watch & electron .",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.puntoventa.desktop",
    "productName": "PuntoVenta",
    "directories": {
      "output": "../../dist/installer",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../www",
        "to": "www",
        "filter": ["**/*"]
      },
      {
        "from": "../../apps/api/dist",
        "to": "api",
        "filter": ["**/*"]
      },
      {
        "from": "../../node_modules/.prisma",
        "to": "prisma-client",
        "filter": ["**/*"]
      },
      {
        "from": "../../prisma",
        "to": "prisma",
        "filter": ["schema.prisma", "migrations/**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PuntoVenta"
    },
    "publish": {
      "provider": "generic",
      "url": "https://updates.puntoventa.local/"
    }
  },
  "dependencies": {
    "@puntoventa/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "typescript": "~5.9.0"
  }
}
