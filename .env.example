# Base de datos MySQL 8
DATABASE_URL="mysql://root:password@localhost:3306/puntoventa"

# API NestJS
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Modo de operación: STANDALONE | SERVER | CLIENT
APP_MODE=STANDALONE

# Configuración cliente (modo CLIENT)
SERVER_HOST=192.168.1.100
SERVER_PORT=3000

# HTTPS (opcional, producción)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Descubrimiento de red (mDNS)
MDNS_SERVICE_NAME=puntoventa-server
